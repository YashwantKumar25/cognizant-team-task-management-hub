{
  "name": "cognizant-team-task-management-hub",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:shared dev:server dev:web",
    "dev:shared": "npm --workspace @cognizant-team-task-management-hub/shared run dev",
    "dev:server": "npm --workspace @cognizant-team-task-management-hub/server run dev",
    "dev:web": "npm --workspace @cognizant-team-task-management-hub/web run dev",
    "build": "npm-run-all build:shared build:server build:web",
    "build:shared": "npm --workspace @cognizant-team-task-management-hub/shared run build",
    "build:server": "npm --workspace @cognizant-team-task-management-hub/server run build",
    "build:web": "npm --workspace @cognizant-team-task-management-hub/web run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11"
  }
}